{
  "name": "next-js-boilerplate",
  "author": "Quaid Ahmed (https://github.com/quaid5050)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:next": "next dev",
    "dev": "npm-run-all --parallel dev:*",
    "build:next": "next build --webpack",
    "build": "pnpm run build:next",
    "build-local": "next build",
    "start": "next start",
    "build-stats": "cross-env ANALYZE=true pnpm run build",
    "clean": "rimraf .next out coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "test": "vitest run"
  },
  "dependencies": {
    "@arcjet/next": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "framer-motion": "^12.40.0",
    "import-in-the-middle": "^2.0.6",
    "lucide-react": "^0.577.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "nuqs": "^2.8.9",
    "posthog-js": "^1.392.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "require-in-the-middle": "^8.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "use-debounce": "^10.1.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.7.3",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@faker-js/faker": "^10.5.0",
    "@lingual/i18n-check": "^0.9.5",
    "@next/bundle-analyzer": "^16.2.9",
    "@next/eslint-plugin-next": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-tailwindcss": "^4.0.3",
    "knip": "^5.88.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      "@semantic-release/release-notes-generator",
      "@semantic-release/github"
    ]
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
